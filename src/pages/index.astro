---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-content">
        <h1>CHAPO Barcelona</h1>
        <p>Confianza, Calidad y Profesionalismo en cada proyecto</p>
        <div class="hero-buttons">
          <a href="#servicios" class="btn btn-primary">Ver Servicios</a>
          <a href="#contacto" class="btn btn-secondary">Contactanos</a>
        </div>
      </div>
    </section>

    <!-- Servicios Section -->
    <section id="servicios" class="servicios">
      <div class="container">
        <h2>Nuestros Servicios</h2>
        <p class="subtitle">Soluciones integrales para tus necesidades</p>

        <div class="servicios-grid">
          <!-- Mudanzas -->
          <div class="servicio-card">
            <div class="icon">🚚</div>
            <h3>Mudanzas</h3>
            <p>Trasporte seguro de tus pertenencias a cualquier lugar</p>
            <ul class="features">
              <li>✓ Equipo profesional</li>
              <li>✓ Embalaje incluido</li>
              <li>✓ Seguro de cobertura</li>
            </ul>
            <div class="precio">
              <span class="precio-desde">Desde</span>
              <span class="precio-valor">300€</span>
              <span class="precio-nota">por mudanza local</span>
            </div>
          </div>

          <!-- Pintura -->
          <div class="servicio-card">
            <div class="icon">🎨</div>
            <h3>Pintura</h3>
            <p>Transforma tus espacios con sus nuevos colores</p>
            <ul class="features">
              <li>✓ Preparación de superficies</li>
              <li>✓ Pintura de calidad premium</li>
              <li>✓ Acabado profesional</li>
            </ul>
            <div class="precio">
              <span class="precio-desde">Desde</span>
              <span class="precio-valor">15€/m²</span>
              <span class="precio-nota">mano de obra</span>
            </div>
          </div>

          <!-- Pequeñas Obras -->
          <div class="servicio-card">
            <div class="icon">🔨</div>
            <h3>Pequeñas Obras</h3>
            <p>Reparaciones y mejoras en tu hogar</p>
            <ul class="features">
              <li>✓ Carpintería e instalaciones</li>
              <li>✓ Mantenimiento general</li>
              <li>✓ Presupuestos personalizados</li>
            </ul>
            <div class="precio">
              <span class="precio-desde">Desde</span>
              <span class="precio-valor">50€/hora</span>
              <span class="precio-nota">mano de obra</span>
            </div>
          </div>

          <!-- Cocinas -->
          <div class="servicio-card">
            <div class="icon">🍳</div>
            <h3>Diseño y Reforma de Cocinas</h3>
            <p>Cocinas modernas y funcionales a medida</p>
            <ul class="features">
              <li>✓ Diseño personalizado</li>
              <li>✓ Instalación completa</li>
              <li>✓ Materiales de calidad</li>
            </ul>
            <div class="precio">
              <span class="precio-desde">Desde</span>
              <span class="precio-valor">2500€</span>
              <span class="precio-nota">proyecto completo</span>
            </div>
          </div>

          <!-- Casas Container -->
          <div class="servicio-card">
            <div class="icon">📦</div>
            <h3>Construcción Container</h3>
            <p>Viviendas modernas y sostenibles con containers</p>
            <ul class="features">
              <li>✓ Diseño innovador</li>
              <li>✓ Construcción rápida</li>
              <li>✓ Eco-friendly</li>
            </ul>
            <div class="precio">
              <span class="precio-desde">Desde</span>
              <span class="precio-valor">45.000€</span>
              <span class="precio-nota">unidad completa</span>
            </div>
          </div>

          <!-- Consultoría -->
          <div class="servicio-card">
            <div class="icon">💡</div>
            <h3>Consultoría y Diseño</h3>
            <p>Asesoramiento profesional en tus proyectos</p>
            <ul class="features">
              <li>✓ Análisis de proyectos</li>
              <li>✓ Planificación integral</li>
              <li>✓ Seguimiento técnico</li>
            </ul>
            <div class="precio">
              <span class="precio-desde">Desde</span>
              <span class="precio-valor">100€/hora</span>
              <span class="precio-nota">consulta profesional</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Por qué elegirnos -->
    <section class="por-que-nos">
      <div class="container">
        <h2>¿Por qué elegirnos?</h2>
        <div class="razones-grid">
          <div class="razon">
            <div class="numero">1</div>
            <h3>Experiencia Probada</h3>
            <p>
              Más de 10 años de trayectoria en el sector con miles de clientes
              satisfechos
            </p>
          </div>
          <div class="razon">
            <div class="numero">2</div>
            <h3>Equipo Profesional</h3>
            <p>
              Personal altamente capacitado y certificado en todas las
              disciplinas
            </p>
          </div>
          <div class="razon">
            <div class="numero">3</div>
            <h3>Transparencia</h3>
            <p>
              Presupuestos claros sin sorpresas, con desglose detallado de
              costos
            </p>
          </div>
          <div class="razon">
            <div class="numero">4</div>
            <h3>Cumplimiento</h3>
            <p>
              Entrega puntual y respeto de plazos en todos nuestros proyectos
            </p>
          </div>
          <div class="razon">
            <div class="numero">5</div>
            <h3>Garantía</h3>
            <p>
              Garantía en trabajos y asistencia post-venta para tu tranquilidad
            </p>
          </div>
          <div class="razon">
            <div class="numero">6</div>
            <h3>Sostenibilidad</h3>
            <p>
              Comprometidos con prácticas sostenibles y respetuosas con el medio
              ambiente
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Contacto -->
    <section id="contacto" class="contacto">
      <div class="container">
        <h2>Contactanos Hoy</h2>
        <p class="subtitle">Recibe tu presupuesto sin compromiso</p>

        <div class="contacto-content">
          <div class="contacto-info">
            <div class="info-item">
              <h3>📞 Teléfono</h3>
              <p><a href="tel:+34932123456">+34 93 212 34 56</a></p>
            </div>
            <div class="info-item">
              <h3>✉️ Email</h3>
              <p>
                <a href="mailto:info@chapobarcelona.es"
                  >info@chapobarcelona.es</a
                >
              </p>
            </div>
            <div class="info-item">
              <h3>📍 Ubicación</h3>
              <p>Barcelona, Catalonia, España</p>
            </div>
            <div class="info-item">
              <h3>⏰ Horario</h3>
              <p>Lunes a Viernes: 9:00 - 19:00</p>
              <p>Sábados: 10:00 - 14:00</p>
            </div>
          </div>

          <form class="contacto-form">
            <div class="form-group">
              <input type="text" placeholder="Tu nombre" required />
            </div>
            <div class="form-group">
              <input type="email" placeholder="Tu email" required />
            </div>
            <div class="form-group">
              <input type="tel" placeholder="Tu teléfono" required />
            </div>
            <div class="form-group">
              <select required>
                <option value="">Selecciona un servicio</option>
                <option value="mudanza">Mudanzas</option>
                <option value="pintura">Pintura</option>
                <option value="obras">Pequeñas Obras</option>
                <option value="cocina">Reforma Cocina</option>
                <option value="container">Casa Container</option>
                <option value="consulta">Consultoría</option>
              </select>
            </div>
            <div class="form-group">
              <textarea placeholder="Cuéntanos sobre tu proyecto..." required
              ></textarea>
            </div>
            <button type="submit" class="btn btn-primary"
              >Enviar Solicitud</button
            >
          </form>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="container">
        <p>&copy; 2026 CHAPO Barcelona. Todos los derechos reservados.</p>
        <p>Expertos en mudanzas, reformas y construcción con containers</p>
      </div>
    </footer>

    <!-- WhatsApp Button -->
    <a
      href="https://wa.me/34647592510"
      class="whatsapp-btn"
      target="_blank"
      rel="noopener noreferrer"
      title="Contactanos por WhatsApp"
    >
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M12 2C6.48 2 2 6.48 2 12c0 1.54.34 3.01.97 4.33L2.05 22l6.29-1.88C10.19 21.65 11.08 22 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2zm0 18c-.88 0-1.74-.18-2.55-.51l-.18-.09-1.87.56.58-1.81-.12-.18C4.48 15.85 4 13.98 4 12c0-4.41 3.59-8 8-8s8 3.59 8 8-3.59 8-8 8z"
          fill="currentColor"></path>
        <path
          d="M16.67 13.13c-.28-.14-1.66-.82-1.92-.92-.26-.09-.45-.14-.64.14-.18.28-.71.92-.87 1.11-.15.19-.31.21-.59.07-1.49-.74-2.47-1.35-3.45-3.07-.26-.46.26-.43.77-1.38.09-.18.04-.34-.05-.48-.09-.14-.64-1.54-.87-2.1-.23-.57-.46-.48-.64-.49-.16-.01-.35-.01-.54-.01-.18 0-.48.07-.73.36-.25.29-.96.94-.96 2.29 0 1.35.98 2.66 1.12 2.85.14.19 1.96 3.02 4.77 4.21 2.81 1.19 2.81.79 3.32.74.51-.05 1.66-.68 1.89-1.34.23-.66.23-1.22.16-1.34-.07-.12-.26-.19-.54-.33z"
          fill="currentColor"></path>
      </svg>
    </a>
  </main>

  <style>
    :root {
      --primary: #2563eb;
      --secondary: #1e40af;
      --accent: #f59e0b;
      --dark: #1f2937;
      --light: #f9fafb;
      --gray: #e5e7eb;
    }

    html {
      scroll-behavior: smooth;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    main {
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      color: var(--dark);
      line-height: 1.6;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    /* Hero Section */
    .hero {
      background: linear-gradient(
        135deg,
        var(--primary) 0%,
        var(--secondary) 100%
      );
      color: white;
      padding: 120px 20px;
      text-align: center;
      min-height: 600px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero-content h1 {
      font-size: 3.5rem;
      margin-bottom: 20px;
      font-weight: 800;
      text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
    }

    .hero-content p {
      font-size: 1.3rem;
      margin-bottom: 40px;
      opacity: 0.95;
    }

    .hero-buttons {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* Botones */
    .btn {
      padding: 15px 40px;
      font-size: 1rem;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      transition: all 0.3s ease;
      font-weight: 600;
    }

    .btn-primary {
      background: var(--accent);
      color: white;
    }

    .btn-primary:hover {
      background: #d97706;
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(245, 158, 11, 0.3);
    }

    .btn-secondary {
      background: white;
      color: var(--primary);
    }

    .btn-secondary:hover {
      background: var(--light);
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

    /* Servicios */
    .servicios {
      padding: 80px 20px;
      background: var(--light);
    }

    .servicios h2 {
      font-size: 2.5rem;
      text-align: center;
      margin-bottom: 10px;
      color: var(--dark);
    }

    .subtitle {
      text-align: center;
      font-size: 1.1rem;
      color: #6b7280;
      margin-bottom: 50px;
    }

    .servicios-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
      gap: 30px;
      margin-top: 40px;
    }

    .servicio-card {
      background: white;
      padding: 40px 30px;
      border-radius: 12px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
      transition: all 0.3s ease;
      border-top: 4px solid var(--primary);
    }

    .servicio-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
    }

    .servicio-card .icon {
      font-size: 3rem;
      margin-bottom: 15px;
    }

    .servicio-card h3 {
      font-size: 1.5rem;
      margin-bottom: 12px;
      color: var(--dark);
    }

    .servicio-card p {
      color: #6b7280;
      margin-bottom: 20px;
      font-size: 0.95rem;
    }

    .features {
      list-style: none;
      margin-bottom: 25px;
      padding-bottom: 25px;
      border-bottom: 1px solid var(--gray);
    }

    .features li {
      color: #374151;
      margin-bottom: 8px;
      font-size: 0.95rem;
    }

    .precio {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 20px;
      background: var(--light);
      border-radius: 8px;
      text-align: center;
    }

    .precio-desde {
      font-size: 0.85rem;
      color: #6b7280;
      margin-bottom: 5px;
    }

    .precio-valor {
      font-size: 2rem;
      font-weight: 700;
      color: var(--primary);
    }

    .precio-nota {
      font-size: 0.8rem;
      color: #9ca3af;
    }

    /* Por qué nos */
    .por-que-nos {
      padding: 80px 20px;
      background: white;
    }

    .por-que-nos h2 {
      font-size: 2.5rem;
      text-align: center;
      margin-bottom: 50px;
      color: var(--dark);
    }

    .razones-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 40px;
    }

    .razon {
      text-align: center;
      padding: 20px;
    }

    .razon .numero {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 50px;
      height: 50px;
      background: var(--primary);
      color: white;
      border-radius: 50%;
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 15px;
    }

    .razon h3 {
      font-size: 1.3rem;
      margin-bottom: 10px;
      color: var(--dark);
    }

    .razon p {
      color: #6b7280;
      line-height: 1.6;
    }

    /* Contacto */
    .contacto {
      padding: 80px 20px;
      background: var(--light);
    }

    .contacto h2 {
      font-size: 2.5rem;
      text-align: center;
      margin-bottom: 10px;
      color: var(--dark);
    }

    .contacto-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      margin-top: 50px;
    }

    .contacto-info {
      display: flex;
      flex-direction: column;
      gap: 30px;
    }

    .info-item h3 {
      font-size: 1.2rem;
      margin-bottom: 8px;
      color: var(--dark);
    }

    .info-item p {
      color: #6b7280;
      font-size: 0.95rem;
    }

    .info-item a {
      color: var(--primary);
      text-decoration: none;
      font-weight: 600;
    }

    .info-item a:hover {
      text-decoration: underline;
    }

    .contacto-form {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 15px;
      border: 1px solid var(--gray);
      border-radius: 8px;
      font-size: 1rem;
      font-family: inherit;
      transition: border-color 0.3s ease;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }

    .form-group textarea {
      resize: vertical;
      min-height: 120px;
    }

    /* Footer */
    .footer {
      background: var(--dark);
      color: white;
      padding: 40px 20px;
      text-align: center;
    }

    .footer p {
      margin-bottom: 8px;
    }

    .footer p:last-child {
      opacity: 0.8;
      font-size: 0.9rem;
    }

    /* WhatsApp Button */
    .whatsapp-btn {
      position: fixed;
      bottom: 30px;
      right: 30px;
      width: 60px;
      height: 60px;
      background: #25d366;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      text-decoration: none;
      box-shadow: 0 4px 12px rgba(37, 211, 102, 0.4);
      transition: all 0.3s ease;
      z-index: 999;
    }

    .whatsapp-btn:hover {
      background: #20ba58;
      transform: scale(1.1);
      box-shadow: 0 6px 20px rgba(37, 211, 102, 0.6);
    }

    .whatsapp-btn svg {
      width: 30px;
      height: 30px;
    }

    @media (max-width: 768px) {
      .whatsapp-btn {
        bottom: 20px;
        right: 20px;
        width: 55px;
        height: 55px;
      }

      .whatsapp-btn svg {
        width: 26px;
        height: 26px;
      }
    }

    /* Media Queries */
    @media (max-width: 768px) {
      .hero-content h1 {
        font-size: 2.5rem;
      }

      .hero-content p {
        font-size: 1.1rem;
      }

      .servicios-grid {
        grid-template-columns: 1fr;
      }

      .contacto-content {
        grid-template-columns: 1fr;
        gap: 40px;
      }

      .servicios h2,
      .por-que-nos h2,
      .contacto h2 {
        font-size: 2rem;
      }

      .hero-buttons {
        flex-direction: column;
        align-items: center;
      }

      .btn {
        width: 100%;
        max-width: 300px;
      }
    }
  </style>
</Layout>
